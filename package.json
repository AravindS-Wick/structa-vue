{
  "name": "@structa/ui-vue",
  "version": "0.1.0",
  "description": "Vue 3 components for Structa UI — Composition API, TypeScript-first, built for teams",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.writeFileSync('dist/index.d.ts','export * from \\'../aravindhan-ui-mat/packages/vue/src/index\\';\\n')\"",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": ">=3.4",
    "@structa/ui": ">=0.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": ["vue", "vue3", "ui", "components", "structa", "design-system", "typescript"],
  "license": "MIT",
  "homepage": "https://structa.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/AravindS-Wick/structa-ui.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
